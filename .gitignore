# Ignore everything
*

# Allow directory traversal
!*/

# =========================
# ROOT FILES
# =========================

!.gitignore
!README.md

# =========================
# GITHUB ACTIONS
# =========================

!.github/
!.github/workflows/
!.github/workflows/**

# =========================
# UNITY PACKAGES
# =========================

!Packages/
!Packages/manifest.json
!Packages/packages-lock.json

# =========================
# DOCUMENTATION
# =========================

!docs/
!docs/**

# =========================
# SCRIPTS ONLY
# =========================

!Assets/
!Assets/_Scripts/
!Assets/_Scripts/**

# =========================
# OPTIONAL UNITY META FILES
# =========================

!Assets/_Scripts.meta
!Assets/_Scripts/**/*.meta
!Packages/*.meta
!docs/**/*.meta

# =========================
# UNITY GENERATED / TEMP
# =========================

[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
.vs/
.gradle/

# =========================
# IDE FILES
# =========================

*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
*.DotSettings.user

